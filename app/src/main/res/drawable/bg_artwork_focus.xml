<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/ui_radius_none" />
            <solid android:color="@color/ui_transparent" />
            <stroke android:width="@dimen/ui_stroke_artwork_focus" android:color="@color/ui_accent_blue_stroke" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="@dimen/ui_radius_none" />
            <solid android:color="@color/ui_transparent" />
            <stroke android:width="@dimen/ui_stroke_artwork_focus" android:color="@color/ui_accent_blue_stroke_soft" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/ui_radius_none" />
            <solid android:color="@color/ui_transparent" />
        </shape>
    </item>
</selector>
