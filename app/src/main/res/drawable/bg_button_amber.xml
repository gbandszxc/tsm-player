<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/ui_radius_button" />
            <solid android:color="@color/ui_accent_amber_focus" />
            <stroke android:width="@dimen/ui_stroke_focus" android:color="@color/ui_accent_amber_stroke" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/ui_radius_button" />
            <solid android:color="@color/ui_accent_amber" />
        </shape>
    </item>
</selector>
