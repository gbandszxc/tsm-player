<?xml version="1.0" encoding="utf-8"?>
<!-- 设置页主布局：左侧分类面板 + 右侧详情面板 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_bg_app"
    android:orientation="horizontal">

    <!-- 左侧：分类面板（固定宽度，方便遥控器聚焦） -->
    <LinearLayout
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:background="@color/ui_bg_sidebar"
        android:orientation="vertical"
        android:padding="@dimen/ui_space_4xl">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:paddingBottom="@dimen/ui_space_4xl"
            style="@style/TsmTextPageTitle" />

        <!-- 分类列表（动态填充）：小屏触摸设备可纵向滑动 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/container_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/ui_divider" />

    <!-- 右侧：详情面板（自适应剩余宽度） -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/container_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ui_space_screen" />

    </ScrollView>

</LinearLayout>
