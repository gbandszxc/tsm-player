<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_file_item"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:orientation="vertical"
    android:padding="@dimen/ui_space_lg">

    <ImageView
        android:id="@+id/iv_artwork"
        android:layout_width="match_parent"
        android:layout_height="@dimen/ui_browser_grid_min_item_width"
        android:background="@color/ui_bg_artwork"
        android:contentDescription="@null"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ui_space_md"
        android:ellipsize="end"
        android:fontFamily="@font/misans_medium"
        android:gravity="center"
        android:maxLines="2"
        android:minLines="2"
        android:textColor="@color/ui_text_primary"
        android:textSize="@dimen/ui_text_body_large" />

</LinearLayout>
