<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#172554"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/panel_connection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="【连接管理】"
            android:textColor="#60A5FA"
            android:textSize="28sp"
            android:fontFamily="@font/misans_bold" />

        <TextView
            android:id="@+id/tv_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#EAF2FF"
            android:textSize="24sp"
            android:fontFamily="@font/misans_medium" />

        <TextView
            android:id="@+id/tv_saved_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#CBD5E1"
            android:textSize="22sp"
            android:fontFamily="@font/misans_regular" />

        <Button
            android:id="@+id/btn_manage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minWidth="220dp"
            android:text="管理连接（编辑/切换/新建）"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="@font/misans_medium" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panel_files"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="【文件浏览】"
            android:textColor="#60A5FA"
            android:textSize="28sp"
            android:fontFamily="@font/misans_bold" />

        <TextView
            android:id="@+id/tv_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#25324A"
            android:padding="10dp"
            android:textColor="#EAF2FF"
            android:textSize="22sp"
            android:fontFamily="@font/misans_medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:text="刷新当前目录"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/bg_button_dark"
                android:fontFamily="@font/misans_medium" />

            <Button
                android:id="@+id/btn_retry"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="重试连接"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/bg_button_dark"
                android:fontFamily="@font/misans_medium" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#FCA5A5"
            android:textSize="20sp"
            android:fontFamily="@font/misans_regular"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_files"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panel_playback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="【播放控制】"
            android:textColor="#60A5FA"
            android:textSize="28sp"
            android:fontFamily="@font/misans_bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_play_all"
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:text="播放当前目录（顺序）"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/bg_button_green"
                android:fontFamily="@font/misans_medium" />

            <Button
                android:id="@+id/btn_play_shuffle"
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="播放当前目录（随机）"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@drawable/bg_button_green"
                android:fontFamily="@font/misans_medium" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

