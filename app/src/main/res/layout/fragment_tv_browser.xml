<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#172554">

    <ScrollView
        android:id="@+id/root_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/panel_connection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_panel"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="连接管理"
                    android:textColor="#60A5FA"
                    android:textSize="20sp"
                    android:fontFamily="@font/misans_bold" />

                <TextView
                    android:id="@+id/tv_connection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#EAF2FF"
                    android:textSize="18sp"
                    android:fontFamily="@font/misans_medium" />

                <TextView
                    android:id="@+id/tv_saved_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#CBD5E1"
                    android:textSize="16sp"
                    android:fontFamily="@font/misans_regular" />

                <Button
                    android:id="@+id/btn_manage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:minWidth="180dp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="管理连接"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:background="@drawable/bg_button_primary"
                    android:fontFamily="@font/misans_medium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_playback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_panel"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播放控制"
                    android:textColor="#60A5FA"
                    android:textSize="20sp"
                    android:fontFamily="@font/misans_bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <HorizontalScrollView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:fillViewport="false">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btn_play_all"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="130dp"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:text="顺序播放"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:background="@drawable/bg_button_green"
                                android:fontFamily="@font/misans_medium" />

                            <Button
                                android:id="@+id/btn_play_shuffle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="130dp"
                                android:layout_marginStart="10dp"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:text="随机播放"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:background="@drawable/bg_button_green"
                                android:fontFamily="@font/misans_medium" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <Button
                        android:id="@+id/btn_now_playing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:text="回到当前播放"
                        android:textAllCaps="false"
                        android:textColor="#3A2A00"
                        android:textSize="16sp"
                        android:background="@drawable/bg_button_light_yellow"
                        android:fontFamily="@font/misans_medium"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_panel"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="文件浏览"
                    android:textColor="#60A5FA"
                    android:textSize="20sp"
                    android:fontFamily="@font/misans_bold" />

                <TextView
                    android:id="@+id/tv_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#25324A"
                    android:padding="10dp"
                    android:textColor="#EAF2FF"
                    android:textSize="18sp"
                    android:fontFamily="@font/misans_medium" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none"
                    android:fillViewport="false">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_refresh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="130dp"
                            android:gravity="center"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="刷新当前目录"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:background="@drawable/bg_button_dark"
                            android:fontFamily="@font/misans_medium" />

                        <Button
                            android:id="@+id/btn_retry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="110dp"
                            android:layout_marginStart="10dp"
                            android:gravity="center"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="重试连接"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:background="@drawable/bg_button_dark"
                            android:fontFamily="@font/misans_medium" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="#FCA5A5"
                    android:textSize="15sp"
                    android:fontFamily="@font/misans_regular"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/panel_fast_locate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#1E293B"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_fast_locate_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="快速定位：↑/↓整屏跳  ←/→10%跳  确认接受  返回取消"
                            android:textColor="#BFDBFE"
                            android:textSize="14sp"
                            android:fontFamily="@font/misans_medium" />

                        <TextView
                            android:id="@+id/tv_fast_locate_target"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="#EAF2FF"
                            android:textSize="15sp"
                            android:fontFamily="@font/misans_bold" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/view_fast_locate_track"
                        android:layout_width="18dp"
                        android:layout_height="120dp"
                        android:layout_marginStart="12dp"
                        android:background="#334155">

                        <View
                            android:id="@+id/view_fast_locate_indicator"
                            android:layout_width="match_parent"
                            android:layout_height="18dp"
                            android:layout_gravity="top"
                            android:background="#38BDF8" />
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_files"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_back_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:minWidth="130dp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="⬅ 返回上一级"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:background="@drawable/bg_button_dark"
        android:fontFamily="@font/misans_medium" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        android:minWidth="100dp"
        android:gravity="center"
        android:maxLines="1"
        android:text="设置"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:background="@drawable/bg_button_dark"
        android:fontFamily="@font/misans_medium" />

</FrameLayout>
