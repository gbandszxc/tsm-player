<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_bg_tv_blue">

    <ScrollView
        android:id="@+id/root_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ui_space_4xl">

            <LinearLayout
                android:id="@+id/panel_connection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_panel"
                android:padding="@dimen/ui_space_3xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/browser_connection_section"
                    android:textColor="@color/ui_accent_blue_text"
                    android:textSize="@dimen/ui_text_section_title"
                    android:fontFamily="@font/misans_bold" />

                <TextView
                    android:id="@+id/tv_connection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_md"
                    android:textColor="@color/ui_text_primary"
                    android:textSize="@dimen/ui_text_title"
                    android:fontFamily="@font/misans_medium" />

                <TextView
                    android:id="@+id/tv_saved_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_xs"
                    android:textColor="@color/ui_text_secondary"
                    android:textSize="@dimen/ui_text_body_large"
                    android:fontFamily="@font/misans_regular" />

                <Button
                    android:id="@+id/btn_manage"
                    style="@style/TsmButtonPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_xl"
                    android:minWidth="180dp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/browser_manage_connection"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_playback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ui_space_3xl"
                android:orientation="vertical"
                android:background="@drawable/bg_panel"
                android:padding="@dimen/ui_space_3xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/browser_playback_controls"
                    android:textColor="@color/ui_accent_blue_text"
                    android:textSize="@dimen/ui_text_section_title"
                    android:fontFamily="@font/misans_bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_lg"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_favorites"
                        style="@style/TsmButtonDanger"
                        android:layout_width="@dimen/ui_playback_mode_button_collapsed_width"
                        android:layout_height="wrap_content"
                        android:drawablePadding="@dimen/ui_space_sm"
                        android:gravity="center"
                        android:minWidth="@dimen/ui_playback_mode_button_collapsed_width"
                        android:text=""
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_history"
                        style="@style/TsmButtonWarning"
                        android:layout_width="@dimen/ui_playback_mode_button_collapsed_width"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/ui_space_lg"
                        android:drawablePadding="@dimen/ui_space_sm"
                        android:gravity="center"
                        android:minWidth="@dimen/ui_playback_mode_button_collapsed_width"
                        android:text=""
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_play_all"
                        style="@style/TsmButtonSuccess"
                        android:layout_width="@dimen/ui_playback_mode_button_collapsed_width"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/ui_space_lg"
                        android:drawablePadding="@dimen/ui_space_sm"
                        android:gravity="center"
                        android:minWidth="@dimen/ui_playback_mode_button_collapsed_width"
                        android:text=""
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_play_shuffle"
                        style="@style/TsmButtonSuccess"
                        android:layout_width="@dimen/ui_playback_mode_button_collapsed_width"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/ui_space_lg"
                        android:drawablePadding="@dimen/ui_space_sm"
                        android:gravity="center"
                        android:minWidth="@dimen/ui_playback_mode_button_collapsed_width"
                        android:text=""
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_now_playing"
                        style="@style/TsmButtonWarning"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/ui_space_lg"
                        android:paddingStart="@dimen/ui_space_2xl"
                        android:paddingEnd="@dimen/ui_space_2xl"
                        android:gravity="center"
                        android:singleLine="true"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:text="@string/browser_now_playing"
                        android:textAllCaps="false"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ui_space_3xl"
                android:orientation="vertical"
                android:background="@drawable/bg_panel"
                android:padding="@dimen/ui_space_3xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/browser_file_browser"
                    android:textColor="@color/ui_accent_blue_text"
                    android:textSize="@dimen/ui_text_section_title"
                    android:fontFamily="@font/misans_bold" />

                <TextView
                    android:id="@+id/tv_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_md"
                    android:background="@color/ui_bg_artwork"
                    android:padding="@dimen/ui_space_lg"
                    android:textColor="@color/ui_text_primary"
                    android:textSize="@dimen/ui_text_title"
                    android:fontFamily="@font/misans_medium" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_xl"
                    android:scrollbars="none"
                    android:fillViewport="false">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_refresh"
                            style="@style/TsmButtonDark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="130dp"
                            android:gravity="center"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="@string/browser_refresh_current_dir"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/btn_sort"
                            style="@style/TsmButtonDark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="130dp"
                            android:layout_marginStart="@dimen/ui_space_lg"
                            android:gravity="center"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="@string/browser_sort_name_asc"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_lg"
                    android:textColor="@color/ui_text_error"
                    android:textSize="@dimen/ui_text_body_medium"
                    android:fontFamily="@font/misans_regular"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/container_files"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_lg"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_back_top"
        style="@style/TsmButtonDark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="@dimen/ui_space_4xl"
        android:layout_marginTop="@dimen/ui_space_xl"
        android:minWidth="130dp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="@string/browser_back_parent"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btn_browse_mode"
        style="@style/TsmButtonDark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginEnd="@dimen/ui_browser_mode_button_end_margin"
        android:layout_marginTop="@dimen/ui_space_xl"
        android:minWidth="100dp"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/browser_mode_nas"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btn_settings"
        style="@style/TsmButtonDark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginEnd="@dimen/ui_space_4xl"
        android:layout_marginTop="@dimen/ui_space_xl"
        android:minWidth="100dp"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/browser_settings"
        android:textAllCaps="false" />

    <LinearLayout
        android:id="@+id/panel_fast_locate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/ui_space_4xl"
        android:layout_marginBottom="@dimen/ui_space_4xl"
        android:background="@color/ui_bg_overlay"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/ui_space_2xl"
        android:paddingTop="@dimen/ui_space_xl"
        android:paddingEnd="@dimen/ui_space_xl"
        android:paddingBottom="@dimen/ui_space_xl"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_fast_locate_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/browser_fast_locate_hint"
                android:textColor="@color/ui_text_primary"
                android:textSize="@dimen/ui_text_body_large"
                android:fontFamily="@font/misans_bold" />

            <TextView
                android:id="@+id/tv_fast_locate_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ui_space_md"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/ui_accent_blue_stroke_soft"
                android:textSize="@dimen/ui_text_body"
                android:fontFamily="@font/misans_medium" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/view_fast_locate_track"
            android:layout_width="18dp"
            android:layout_height="136dp"
            android:layout_marginStart="@dimen/ui_space_2xl"
            android:background="@color/ui_bg_track">

            <View
                android:id="@+id/view_fast_locate_indicator"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:layout_gravity="top"
                android:background="@color/ui_accent_cyan" />
        </FrameLayout>
    </LinearLayout>

</FrameLayout>
