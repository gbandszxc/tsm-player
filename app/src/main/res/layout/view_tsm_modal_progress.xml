<?xml version="1.0" encoding="utf-8"?>
<!-- Modal 进度视图：文件名 + 进度条 + 百分比 + 说明 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 文件名 -->
    <TextView
        android:id="@+id/tv_modal_progress_filename"
        style="@style/TsmTextSecondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/ui_text_body"
        android:layout_marginBottom="@dimen/ui_space_md" />

    <!-- 进度条 + 百分比 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/ui_space_md">

        <ProgressBar
            android:id="@+id/pb_modal_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tv_modal_progress_percent"
            style="@style/TsmTextPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/ui_text_body"
            android:layout_marginStart="@dimen/ui_space_md"
            android:minWidth="48dp"
            android:gravity="end" />

    </LinearLayout>

    <!-- 说明文案 -->
    <TextView
        android:id="@+id/tv_modal_progress_message"
        style="@style/TsmTextSecondary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/ui_text_body" />

</LinearLayout>
