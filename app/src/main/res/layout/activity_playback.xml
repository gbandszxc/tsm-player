<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#172554"
    android:padding="16dp">

    <!-- 上方主内容区：封面 + 信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 封面区：SquareFrameLayout 保证宽高相等，centerCrop 裁剪非正方形图片 -->
        <com.github.gbandszxc.tvmediaplayer.ui.SquareFrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:layout_gravity="center_vertical"
            android:background="#25324A"
            android:clipChildren="true"
            android:clipToPadding="true">

            <ImageView
                android:id="@+id/iv_artwork"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground" />
        </com.github.gbandszxc.tvmediaplayer.ui.SquareFrameLayout>

        <!-- 信息区：占 70%，内部垂直排列，歌词 ScrollView 撑满剩余高度 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="7"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_playback_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="歌曲：暂无播放内容"
                android:textColor="#EAF2FF"
                android:textSize="28sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="@font/misans_bold" />

            <TextView
                android:id="@+id/tv_playback_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="艺术家：-"
                android:textColor="#CBD5E1"
                android:textSize="18sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans_regular" />

            <TextView
                android:id="@+id/tv_playback_album"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="专辑：-"
                android:textColor="#CBD5E1"
                android:textSize="18sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans_regular" />

            <TextView
                android:id="@+id/tv_playback_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="00:00 / 00:00"
                android:textColor="#EAF2FF"
                android:textSize="16sp"
                android:fontFamily="@font/misans_medium" />

            <SeekBar
                android:id="@+id/pb_playback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:max="1000"
                android:progressTint="#34D399"
                android:progressBackgroundTint="#334155"
                android:thumbTint="#EAF2FF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="歌词："
                android:textColor="#60A5FA"
                android:textSize="18sp"
                android:fontFamily="@font/misans_bold" />

            <!-- 歌词滚动区：与全屏逻辑一致，当前行高亮，自动滚动 -->
            <ScrollView
                android:id="@+id/scroll_lyrics"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:fadeScrollbars="false"
                android:scrollbars="none">

                <TextView
                    android:id="@+id/tv_lyric_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#94A3B8"
                    android:textSize="17sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="@font/misans_regular" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- 底部按钮栏：HorizontalScrollView 防止小屏溢出，支持方向键导航 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="100dp"
                android:text="上一首"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_button_dark"
                android:fontFamily="@font/misans_medium" />

            <Button
                android:id="@+id/btn_play_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:minWidth="100dp"
                android:text="播放"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_button_green"
                android:fontFamily="@font/misans_medium" />

            <Button
                android:id="@+id/btn_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:minWidth="100dp"
                android:text="下一首"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_button_dark"
                android:fontFamily="@font/misans_medium" />

            <Button
                android:id="@+id/btn_lyrics_fullscreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:minWidth="120dp"
                android:text="歌词全屏"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_button_primary"
                android:fontFamily="@font/misans_medium" />

            <Button
                android:id="@+id/btn_back_to_browser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:minWidth="120dp"
                android:text="返回文件页"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_button_primary"
                android:fontFamily="@font/misans_medium" />
        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
