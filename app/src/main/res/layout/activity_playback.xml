<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/ui_bg_tv_blue"
        android:padding="@dimen/ui_space_4xl">

        <!-- 上方主内容区：封面 + 信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- 封面区：SquareFrameLayout 保证宽高相等，centerCrop 裁剪非正方形图片 -->
            <com.github.gbandszxc.tvmediaplayer.ui.SquareFrameLayout
                android:id="@+id/layout_artwork_frame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:layout_gravity="center_vertical"
                android:background="@color/ui_bg_artwork"
                android:clickable="true"
                android:clipChildren="true"
                android:clipToPadding="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:foreground="@drawable/bg_artwork_focus"
                android:nextFocusRight="@id/pb_playback"
                android:nextFocusDown="@id/pb_playback">

                <ImageView
                    android:id="@+id/iv_artwork"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:focusable="false"
                    android:scaleType="centerCrop"
                    android:src="@drawable/default_cover" />
            </com.github.gbandszxc.tvmediaplayer.ui.SquareFrameLayout>

            <!-- 信息区：占 70%，内部垂直排列，歌词 ScrollView 撑满剩余高度 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="7"
                android:layout_marginStart="@dimen/ui_space_4xl"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_playback_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="歌曲：暂无播放内容"
                    android:textColor="@color/ui_text_primary"
                    android:textSize="@dimen/ui_text_hero"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:fontFamily="@font/misans_bold" />

                <TextView
                    android:id="@+id/tv_playback_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_lg"
                    android:text="艺术家：-"
                    android:textColor="@color/ui_text_secondary"
                    android:textSize="@dimen/ui_text_title"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/misans_regular" />

                <TextView
                    android:id="@+id/tv_playback_album"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_sm"
                    android:text="专辑：-"
                    android:textColor="@color/ui_text_secondary"
                    android:textSize="@dimen/ui_text_title"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/misans_regular" />

                <TextView
                    android:id="@+id/tv_playback_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_3xl"
                    android:text="00:00 / 00:00"
                    android:textColor="@color/ui_text_primary"
                    android:textSize="@dimen/ui_text_body_large"
                    android:fontFamily="@font/misans_medium" />

                <SeekBar
                    android:id="@+id/pb_playback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_md"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:nextFocusUp="@id/layout_artwork_frame"
                    android:nextFocusDown="@id/btn_prev"
                    android:nextFocusLeft="@id/layout_artwork_frame"
                    android:max="10000"
                    android:progressTint="@color/ui_accent_green_text"
                    android:progressBackgroundTint="@color/ui_bg_track"
                    android:thumbTint="@color/ui_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ui_space_3xl"
                    android:text="歌词："
                    android:textColor="@color/ui_accent_blue_text"
                    android:textSize="@dimen/ui_text_title"
                    android:fontFamily="@font/misans_bold" />

                <!-- 歌词滚动区：与全屏逻辑一致，当前行高亮，自动滚动 -->
                <com.github.gbandszxc.tvmediaplayer.ui.NonFocusableScrollView
                    android:id="@+id/scroll_lyrics"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="@dimen/ui_space_lg"
                    android:fadeScrollbars="false"
                    android:scrollbars="none"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:descendantFocusability="blocksDescendants">

                    <TextView
                        android:id="@+id/tv_lyric_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ui_text_muted"
                        android:textSize="@dimen/ui_text_section_title"
                        android:lineSpacingExtra="@dimen/ui_space_sm"
                        android:fontFamily="@font/misans_regular"
                        android:focusable="false" />
                </com.github.gbandszxc.tvmediaplayer.ui.NonFocusableScrollView>
            </LinearLayout>
        </LinearLayout>

        <!-- 底部按钮栏：HorizontalScrollView 防止小屏溢出，支持方向键导航 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ui_space_3xl"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_prev"
                    style="@style/TsmButtonDark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="100dp"
                    android:nextFocusUp="@id/pb_playback"
                    android:text="上一首"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_play_pause"
                    style="@style/TsmButtonSuccess"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/ui_space_lg"
                    android:minWidth="100dp"
                    android:nextFocusUp="@id/pb_playback"
                    android:text="播放"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_next"
                    style="@style/TsmButtonDark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/ui_space_lg"
                    android:minWidth="100dp"
                    android:nextFocusUp="@id/pb_playback"
                    android:text="下一首"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_play_mode"
                    style="@style/TsmButtonSuccess"
                    android:layout_width="@dimen/ui_playback_mode_button_collapsed_width"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/ui_space_lg"
                    android:drawablePadding="@dimen/ui_space_sm"
                    android:gravity="center"
                    android:minWidth="@dimen/ui_playback_mode_button_collapsed_width"
                    android:nextFocusUp="@id/pb_playback"
                    android:text=""
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_lyrics_fullscreen"
                    style="@style/TsmButtonPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/ui_space_lg"
                    android:minWidth="120dp"
                    android:nextFocusUp="@id/pb_playback"
                    android:text="歌词全屏"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_back_to_browser"
                    style="@style/TsmButtonPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/ui_space_lg"
                    android:minWidth="120dp"
                    android:nextFocusUp="@id/pb_playback"
                    android:text="返回文件页"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_locate"
                    style="@style/TsmButtonWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/ui_space_lg"
                    android:minWidth="120dp"
                    android:nextFocusUp="@id/pb_playback"
                    android:text="定位"
                    android:textAllCaps="false" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_artwork_fullscreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ui_bg_black"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_artwork_fullscreen_blur"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.78"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/iv_artwork_fullscreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_playback_toast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="@dimen/ui_space_4xl"
        android:layout_marginEnd="@dimen/ui_space_4xl"
        android:background="@drawable/bg_playback_toast"
        android:fontFamily="@font/misans_medium"
        android:paddingStart="@dimen/ui_space_3xl"
        android:paddingTop="@dimen/ui_space_lg"
        android:paddingEnd="@dimen/ui_space_3xl"
        android:paddingBottom="@dimen/ui_space_lg"
        android:textColor="@color/ui_text_primary"
        android:textSize="@dimen/ui_text_body_large"
        android:visibility="gone" />
</FrameLayout>
